# Copy to .env and fill in.
DISCORD_WEBHOOK_URL=

# Optional. If unset, the scout auto-discovers the docker-compose port via
# `docker compose port postgres 5432` and connects using the default creds
# from docker-compose.yml (scout/scout). Set this only if you're pointing at
# a non-compose Postgres.
# DATABASE_URL=postgresql://scout:scout@127.0.0.1:5432/tiktok_live_scout
